# ── Capture provider ─────────────────────────────────────────────
# local    : @sparticuz/chromium on the Netlify function (default)
# crawlsnap: delegate to the deployed crawlsnap-browser /harvest endpoint
CAPTURE_PROVIDER=local

# ── Residential proxy (always-on) ────────────────────────────────
# Your own residential proxy. Rotating endpoint — NO sticky / session-affinity IP.
PROXY_HOST=proxy.crawlsnap.com
PROXY_PORT=823
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password

# ── crawlsnap-browser remote provider ────────────────────────────
CRAWLSNAP_HARVEST_URL=https://crawlsnap-browser.fly.dev/harvest
CRAWLSNAP_API_KEY=your-crawlsnap-api-key

# ── Local dev only ───────────────────────────────────────────────
# Path to a real Chrome for the `local` provider when running on macOS
# (the @sparticuz/chromium binary is Linux/Lambda-only). Leave unset on Netlify.
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
